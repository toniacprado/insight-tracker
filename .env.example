# Copy to .env and fill in only the keys your project actually needs.
APP_ENV=development
LOG_LEVEL=INFO

# Keep unset in production. This only exists for temporary development previews.
# ALLOW_DEVELOPMENT_AUTH_PREVIEW=false

# Hosted app URL used by auth redirect configuration.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase provider set for hosted auth, Postgres, and private storage.
# Vercel Marketplace creates the URL, anon key, and service role key automatically.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# App-specific bucket name to create in Supabase Storage before audio upload.
# SUPABASE_STORAGE_BUCKET=raw-captures

# AI provider keys stay unset until real model processing is explicitly enabled.
# OPENAI_API_KEY=
# OPENAI_PROJECT_ID=
