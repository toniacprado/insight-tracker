# Example rules for project-scoped Codex execution policy.
# Copy to `codex/rules/default.rules` after review.

# Never allow force-push from agent automation without explicit human handling.
prefix_rule(pattern=["git", "push", "--force"], decision="forbidden")

# Never allow broad destructive file deletes from automation.
prefix_rule(pattern=["rm", "-rf"], decision="forbidden")

# Require explicit prompt before public release actions.
prefix_rule(pattern=["gh", "release", "create"], decision="prompt")

# Require explicit prompt before publication helper scripts.
prefix_rule(pattern=["python", "scripts/publish_release_notes.py"], decision="prompt")
